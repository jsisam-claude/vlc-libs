# Pruned contrib set for the vlc-android privacy fork.
# Goal: local playback of mp4/mkv/webm/avi/ts/m2ts/flv/wmv/ogv/mpg/3gp with
# H.264 / HEVC / MPEG-1/2/4 / VC-1 / VP6/8/9 video, common audio codecs, and
# styled subtitles — everything decoded by ffmpeg or hardware MediaCodec.
#
# Bucket A — vendored as SOURCE TREES from official repositories
# (contrib-src/, exact production tags; archives generated locally by
# make-contrib-tarballs.sh):
ffmpeg      # all software demux/decode (video + audio)
ass         # styled subtitle rendering
freetype2   # font rasterisation (libass dependency)
fribidi     # bidi text shaping (libass dependency)
harfbuzz    # text shaping (libass dependency)
ogg         # ogv/ogg container
ebml        # mkv/webm demux (libebml)
matroska    # mkv/webm demux (libmatroska)

# Bucket B — no official GitHub; official release archives fetched and
# SHA-512-verified by fetch-contribs.sh (videolan mirror or upstream):
gnutls      # TLS: https:// streams and Chromecast (opt-in casting)
nettle      # gnutls dependency
gmp         # gnutls dependency
iconv       # subtitle/charset conversion
dvbpsi      # MPEG-TS (ts/m2ts) demux

# Deliberately dropped from the default android set (examples): dav1d (AV1),
# libvpx (avcodec's VP8/9 decoders are used), vorbis/opus/flac standalone
# decoders (avcodec covers them), live555 (RTSP), smb2/upnp/dvdread/dvdnav/
# bluray, libarchive, taglib-class extras. Re-add any of them by vendoring
# the source the same way and keeping the recipe's pinned version.
#
# Enforcement happens at contrib-bootstrap time in libvlcjni's
# compile-libvlc.sh once vendored: pass the corresponding --disable-<pkg>
# contrib flags / vlc configure flags for everything not in this list.
